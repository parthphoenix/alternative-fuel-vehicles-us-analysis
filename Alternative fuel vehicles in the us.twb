              <zone h='6771' id='12' name='EV Adoption Map' pane-specification-id='0' param='[federated.1ihtjif0gsagbs180le0h1ew67ei].[usr:Calculation_0712233505550336:qk]' type-v2='color' w='9877' x='89629' y='833'>
